// $Id$


// Topology

topology = mesh;
 k = 3;
 n = 2;

// Routing
routing_function = adaptive_xy_yx;

// Flow control
num_vcs     = 6;
vc_buf_size = 8;
wait_for_tail_credit = 1;

// Router architecture
vc_allocator = islip;
sw_allocator = islip;
alloc_iters  = 1;

credit_delay   = 2;
routing_delay  = 0;
vc_alloc_delay = 1;
sw_alloc_delay = 1;

input_speedup     = 2;
output_speedup    = 1;
internal_speedup  = 1.0;
noq=0;


// Traffic
traffic = uniform;
packet_size = {5,8};
injection_rate = {0.05,0.02};
injection_process = bernoulli;


// Simulation
sim_type = latency;

classes = 2;
//class_priority={1,0};



print_csv_results = 0;
watch_out = watch_out.txt;
//watch_packets = {3};
//watch_flits = {12,20};
//watch_transactions = -;
watch_file = watch_file.txt;
viewer_trace = 1;
network_file = network_file;

//Power
sim_power = 1;
//power_output_file = power.txt;
tech_file = src/power/techfile.txt;

arb_type=priority;


speculative=0;


used_credits_out = used_credits_out.txt;
injected_flits_out = injected_flits.txt;
received_flits_out = received_flits.txt;
stored_flits_out = stored_flits.txt;
sent_flits_out = sent_flits.txt;
outstanding_credits_out = outstanding_credits.txt;
ejected_flits_out = ejected_flits.txt;
active_packets_out = active_packets.txt;

stats_out=stats.txt;

print_activity = 1;