// Topology
topology = mesh;
k = 8;
n = 2;

// Routing (will be overridden)
routing_function = dim_order;

// Flow Control
num_vcs = 4;
vc_buf_size = 8;
wait_for_tail_credit = 1;

// Traffic
traffic = uniform;
injection_rate = 0.15;

// Simulation
sim_type = latency;
warmup_periods = 3;
max_samples = 20000;
latency_thres = 500.0;
sim_count = 1;
